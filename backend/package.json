{
  "name": "search-typeahead-backend",
  "version": "1.0.0",
  "description": "HLD101 Search Typeahead — backend (TypeScript): distributed cache w/ consistent hashing, recency-aware trending, batched writes.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "generate": "tsx scripts/generateDataset.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "demo:hashing": "tsx scripts/demoConsistentHashing.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
